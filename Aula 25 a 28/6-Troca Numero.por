programa {
  funcao inicio() {
    inteiro Var1,Var2,Var3
    escreva("Digite o primeiro número: ") leia(Var1)
    escreva("Digite o segundo número: ") leia(Var2)
    escreva("Número1: ",Var1,"  Número 2: ",Var2,"\n")
    escreva("Trocando os conteúdos....","\n")
    Var3=Var1
    Var1=Var2
    Var2=Var3
    escreva("Número1: ",Var1,"  Número 2: ",Var2,"\n")

  }
}
