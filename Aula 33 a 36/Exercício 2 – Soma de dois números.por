programa
{
    funcao inicio()
    {
        inteiro a, b, soma
        //escreva("Digite A: ")
        escreva("Digite o primeiro número da soma: ")
        leia(a)
        //escreva("Digite B: ")
        escreva("Digite o segundo número da soma: ")
        leia(b)

        //soma = a * b
        soma=a+b

        escreva("Soma = ", soma)
    }
}