programa
{
    funcao inicio()
    {
        //inteiro largura, altura
        real largura, altura
        real area

        escreva("Digite a largura da área a ser calculada: ")
        leia(largura)
        escreva("Digite a altura da área a ser calculada: ")
        leia(altura)

        area = largura * altura

        escreva("Área: ", area)
    }
}