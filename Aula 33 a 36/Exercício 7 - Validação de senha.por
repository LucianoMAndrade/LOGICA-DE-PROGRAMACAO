programa
{
    funcao inicio()
    {
        inteiro senha
        escreva("Digite a senha: ")
        leia(senha)
        //se (senha != 1234)
        se (senha==1234)
        {
            escreva("Acesso liberado!")
        }
        senao
        {
            escreva("Senha incorreta!")
        }
    }
}