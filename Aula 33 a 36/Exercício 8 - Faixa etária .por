programa
{
    funcao inicio()
    {
        inteiro idade
        escreva("Digite a sua idade:")
        leia(idade)

        //se (idade >= 12 ou idade <= 17)
        se (idade>=12 e idade<=17)
        {
            escreva("É Adolescente!")
        }
        senao
        {
            escreva("Não é adolescente!")
        }
    }
}